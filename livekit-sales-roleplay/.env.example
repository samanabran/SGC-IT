# LiveKit Cloud or self-hosted server credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram key required for Aura TTS voices
DEEPGRAM_API_KEY=your_deepgram_api_key

# Roleplay tuning
ROLEPLAY_PERSONA_ID=p1_faisal
# available: p1_faisal, p2_noura, p3_omar, p4_rajesh

# Available personas for ROLEPLAY_PERSONA_ID
ROLEPLAY_AVAILABLE_PERSONAS=p1_faisal,p2_noura,p3_omar,p4_rajesh
