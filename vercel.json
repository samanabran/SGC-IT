{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/SGC%20TECH%20AI%20COMPANY%20PROFILE%202025.html",
      "destination": "/SGC%20TECH%20AI%20BUSINESS%20PROFILE.pdf",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/roleplay-token", "destination": "/api/roleplay-token.js" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/card", "destination": "/index-simple.html" },
    { "source": "/business-card", "destination": "/index-simple.html" },
    { "source": "/designer", "destination": "/index-simple.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
